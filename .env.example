# Database
MONGO_URI=mongodb://localhost:27017/openmodelprism

# Server
PORT=3000
NODE_ENV=development
LOG_LEVEL=info

# Security (CHANGE THESE IN PRODUCTION)
JWT_SECRET=change-me-in-production-jwt-secret
ENCRYPTION_KEY=change-me-32-chars-encryption-k!

# Optional
CORS_ORIGINS=*
OFFLINE=false

# License — public key is baked in by default (Ohara Systems Ed25519 key).
# Only override if using a custom license server.
# LICENSE_PUBLIC_KEY=-----BEGIN PUBLIC KEY-----\nMCowBQYDK2VwAyEA...\n-----END PUBLIC KEY-----

# Dev setup prefill — pre-fills the setup wizard form in development (NODE_ENV != production)
# Useful for rapid re-setup during development. Never set in production.
# DEV_ADMIN_USERNAME=admin
# DEV_ADMIN_PASSWORD=testtest
# DEV_PROVIDER_NAME=My Provider
# DEV_PROVIDER_TYPE=openai
# DEV_PROVIDER_URL=http://localhost:8080
# DEV_PROVIDER_KEY=sk-test
