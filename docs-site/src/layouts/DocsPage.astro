---
import Base from './Base.astro';
import DocsSidebar from '../components/DocsSidebar.astro';
import Search from '../components/Search.astro';

interface Props {
  title: string;
  description: string;
}

const { title, description } = Astro.props;
---

<Base title={title} description={description} lang="en">
  <div class="flex min-h-screen">
    <aside class="hidden lg:block w-64 flex-shrink-0 sticky top-16 h-[calc(100vh-4rem)] overflow-y-auto border-r border-white/8 bg-[#0d0d14]">
      <div class="px-4 pt-4 pb-2">
        <Search />
      </div>
      <DocsSidebar currentPath={Astro.url.pathname} />
    </aside>
    <main class="flex-1 px-8 py-16 md:px-16 max-w-4xl">
      <slot />
    </main>
  </div>
</Base>

<script>
  // Auto-assign slug IDs to all headings in docs content and add copy-link buttons
  function slugify(text: string): string {
    return text
      .toLowerCase()
      .replace(/[^\w\s-]/g, '')
      .trim()
      .replace(/[\s_]+/g, '-')
      .replace(/-+/g, '-');
  }

  function initHeadingAnchors() {
    const main = document.querySelector('main');
    if (!main) return;

    main.querySelectorAll('h1, h2, h3').forEach((el) => {
      const heading = el as HTMLElement;
      // Only set id if not already set
      if (!heading.id) {
        const text = heading.textContent?.replace(/🥚|#/g, '').trim() ?? '';
        heading.id = slugify(text);
      }

      // Avoid double-adding the link button
      if (heading.querySelector('.anchor-copy-btn')) return;

      heading.style.position = 'relative';
      heading.style.scrollMarginTop = '80px';

      const btn = document.createElement('a');
      btn.className = 'anchor-copy-btn';
      btn.href = '#' + heading.id;
      btn.setAttribute('aria-label', 'Copy link to section');
      btn.title = 'Copy link';
      btn.innerHTML = `<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"/>
        <path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"/>
      </svg>`;
      btn.style.cssText = `
        display: inline-flex; align-items: center; margin-left: 8px;
        opacity: 0; transition: opacity .15s ease; color: rgba(56,189,248,.6);
        text-decoration: none; vertical-align: middle;
      `;

      btn.addEventListener('click', (e) => {
        e.preventDefault();
        const url = window.location.origin + window.location.pathname + '#' + heading.id;
        navigator.clipboard.writeText(url).catch(() => {});
        // Scroll to heading
        heading.scrollIntoView({ behavior: 'smooth', block: 'start' });
        history.pushState(null, '', '#' + heading.id);
        // Brief flash to confirm copy
        btn.style.color = 'rgba(34,197,94,.8)';
        setTimeout(() => { btn.style.color = 'rgba(56,189,248,.6)'; }, 1000);
      });

      heading.addEventListener('mouseenter', () => { btn.style.opacity = '1'; });
      heading.addEventListener('mouseleave', () => { btn.style.opacity = '0'; });

      heading.appendChild(btn);
    });

    // Scroll to hash on page load (now that IDs are set)
    if (window.location.hash) {
      const target = document.getElementById(window.location.hash.slice(1));
      if (target) {
        setTimeout(() => target.scrollIntoView({ behavior: 'smooth', block: 'start' }), 100);
      }
    }
  }

  // Run after DOM is ready
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initHeadingAnchors);
  } else {
    initHeadingAnchors();
  }
</script>
