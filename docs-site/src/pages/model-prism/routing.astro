        <tr><td class="border-t border-white/10 px-4 py-2 text-white/50 text-sm">Length adequacy</td><td class="border-t border-white/10 px-4 py-2 text-white/50 text-sm">20</td><td class="border-t border-white/10 px-4 py-2 text-white/50 text-sm">Response length appropriate for the task complexity</td></tr>
        <tr><td class="border-t border-white/10 px-4 py-2 text-white/50 text-sm">Refusal detection</td><td class="border-t border-white/10 px-4 py-2 text-white/50 text-sm">20</td><td class="border-t border-white/10 px-4 py-2 text-white/50 text-sm">Penalizes unnecessary refusals or safety over-triggers</td></tr>
