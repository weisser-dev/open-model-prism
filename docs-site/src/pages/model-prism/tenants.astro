        <tr><td class="border-t border-white/10 px-4 py-2 text-white/50 text-sm"><code class="bg-white/5 px-1.5 py-0.5 rounded text-[#38bdf8] text-sm font-mono">GET</code></td><td class="border-t border-white/10 px-4 py-2 text-white/50 text-sm"><code class="bg-white/5 px-1.5 py-0.5 rounded text-[#38bdf8] text-sm font-mono">/api/prism/tenant-portal/mine</code></td><td class="border-t border-white/10 px-4 py-2 text-white/50 text-sm">List own tenants</td></tr>
        <tr><td class="border-t border-white/10 px-4 py-2 text-white/50 text-sm"><code class="bg-white/5 px-1.5 py-0.5 rounded text-[#38bdf8] text-sm font-mono">GET</code></td><td class="border-t border-white/10 px-4 py-2 text-white/50 text-sm"><code class="bg-white/5 px-1.5 py-0.5 rounded text-[#38bdf8] text-sm font-mono">/api/prism/tenant-portal/:id</code></td><td class="border-t border-white/10 px-4 py-2 text-white/50 text-sm">Get tenant config (no API key hash)</td></tr>
