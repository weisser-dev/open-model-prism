          </tr>
        ))}
      </tbody>
    </table>
  </div>
  <p class="text-white/55 text-sm mb-6">All dashboard endpoints accept <code class="bg-white/5 px-1.5 py-0.5 rounded text-[#38bdf8] text-sm font-mono">?days=7|30|90</code> and <code class="bg-white/5 px-1.5 py-0.5 rounded text-[#38bdf8] text-sm font-mono">?tenantId=&lt;id&gt;</code>. Tenant-viewer and tenant-admin roles are automatically scoped to their assigned tenants.</p>

  <h3 class="text-lg font-semibold text-white/90 mt-6 mb-2">Benchmarks & Routing Evaluation</h3>
  <p class="text-white/40 text-xs mb-3">Endpoints for AI-driven routing quality analysis, session tracking, and model comparison. Designed to be consumed by an autonomous Benchmark Agent that fine-tunes routing parameters.</p>
  <div class="overflow-x-auto mb-4">
    <table class="w-full border-collapse">
      <thead>
        <tr>
          <th class="bg-white/5 text-left text-white/70 px-4 py-2 text-sm w-20">Method</th>
          <th class="bg-white/5 text-left text-white/70 px-4 py-2 text-sm">Endpoint</th>
          <th class="bg-white/5 text-left text-white/70 px-4 py-2 text-sm">Description</th>
        </tr>
      </thead>
      <tbody>
        {[
          ['GET', '/benchmarks/activity',              'Full activity dump — request, decision, response, cost per request'],
          ['GET', '/benchmarks/sessions',              'List sessions with aggregated stats (tokens, cost, models, errors)'],
          ['GET', '/benchmarks/sessions/:sessionId',   'All requests within one session in chronological order'],
          ['GET', '/benchmarks/evaluate',              'AI evaluation dataset with suggested quality checks'],
          ['GET', '/benchmarks/model-comparison',      'Cross-model performance comparison by category and tier'],
        ].map(([method, path, desc]) => (
          <tr>
            <td class="border-t border-white/10 px-4 py-2 text-sm">
              <span class="inline-block px-1.5 py-0.5 rounded text-xs font-mono font-semibold bg-green-500/10 text-green-400">{method}</span>
            </td>
            <td class="border-t border-white/10 px-4 py-2 text-sm"><code class="bg-white/5 px-1.5 py-0.5 rounded text-white/60 text-xs font-mono">{path}</code></td>
            <td class="border-t border-white/10 px-4 py-2 text-white/50 text-sm">{desc}</td>
          </tr>
        ))}
      </tbody>
    </table>
  </div>

  <h4 class="text-base font-medium text-white/80 mt-4 mb-2">Activity Dump Response Shape</h4>
  <p class="text-white/55 text-sm mb-2">Each entry in <code class="bg-white/5 px-1.5 py-0.5 rounded text-[#38bdf8] text-sm font-mono">/benchmarks/activity</code> contains the complete routing context:</p>
  <pre class="bg-[#0d0d14] border border-white/10 rounded-lg p-4 overflow-x-auto text-sm text-white/70 mb-4 font-mono"><code>&#123;
  "id": "...",
  "timestamp": "2026-04-05T14:30:00Z",
  "sessionId": "abc-123-def",
  "tenant": "my-app",
  "request": &#123;
    "model": "auto-prism",
    "promptSnapshot": &#123; "systemPrompt": "...", "lastUserMessage": "..." &#125;
  &#125;,
  "decision": &#123;
    "routedModel": "claude-sonnet-4-5",
    "category": "coding_generation",
    "costTier": "medium",
    "confidence": 0.92,
    "overrideApplied": null,
    "routingSignals": &#123; "totalTokens": 1200, "hasToolCalls": true &#125;
  &#125;,
  "output": &#123;
    "status": "success",
    "inputTokens": 1200,
    "outputTokens": 840,
    "responseSnapshot": &#123; "content": "Here is the code...", "finishReason": "stop" &#125;
  &#125;,
  "cost": &#123;
    "actualCostUsd": 0.0084,
    "baselineCostUsd": 0.042,
    "savedUsd": 0.0336
  &#125;
&#125;</code></pre>

  <p class="text-white/55 text-sm mb-2">Common query parameters for benchmark endpoints:</p>
  <ul class="list-disc ml-6 text-white/55 text-sm space-y-1 mb-6">
    <li><code class="bg-white/5 px-1.5 py-0.5 rounded text-[#38bdf8] text-sm font-mono">?hours=2</code> — Time window (default: 2 for activity/evaluate, 24 for sessions/comparison)</li>
    <li><code class="bg-white/5 px-1.5 py-0.5 rounded text-[#38bdf8] text-sm font-mono">?tenantId=&lt;id&gt;</code> — Filter by tenant</li>
    <li><code class="bg-white/5 px-1.5 py-0.5 rounded text-[#38bdf8] text-sm font-mono">?sessionId=&lt;id&gt;</code> — Filter by session (activity endpoint)</li>
    <li><code class="bg-white/5 px-1.5 py-0.5 rounded text-[#38bdf8] text-sm font-mono">?autoRoutedOnly=true</code> — Only auto-routed requests (evaluate endpoint)</li>
    <li><code class="bg-white/5 px-1.5 py-0.5 rounded text-[#38bdf8] text-sm font-mono">?category=&lt;key&gt;</code> — Filter by routing category (comparison endpoint)</li>
  </ul>

