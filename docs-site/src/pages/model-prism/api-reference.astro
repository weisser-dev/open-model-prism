          ['POST',   '/categories/apply-preset',   'Apply preset profiles — category benchmarks'],
        ].map(([method, path, desc]) => (
          <tr>
            <td class="border-t border-white/10 px-4 py-2 text-sm">
              <span class={`inline-block px-1.5 py-0.5 rounded text-xs font-mono font-semibold ${
                method === 'GET' ? 'bg-green-500/10 text-green-400' :
                method === 'POST' ? 'bg-blue-500/10 text-blue-400' :
