    <table class="w-full border-collapse">
      <thead>
        <tr>
          <th class="bg-white/5 text-left text-white/70 px-4 py-2 text-sm">Type</th>
          <th class="bg-white/5 text-left text-white/70 px-4 py-2 text-sm">Description</th>
          <th class="bg-white/5 text-left text-white/70 px-4 py-2 text-sm">Notes</th>
        </tr>
      </thead>
      <tbody>
        <tr>
          <td class="border-t border-white/10 px-4 py-2 text-white/50 text-sm"><code class="bg-white/5 px-1.5 py-0.5 rounded text-[#38bdf8] text-sm font-mono">bedrock-proxy</code></td>
          <td class="border-t border-white/10 px-4 py-2 text-white/50 text-sm">AWS Bedrock via Proxy</td>
          <td class="border-t border-white/10 px-4 py-2 text-white/50 text-sm">Legacy option for OpenAI-compatible Bedrock proxies (e.g. bedrock-access-gateway)</td>
        </tr>
        <tr>
